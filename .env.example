PYTHONPATH=src
AECT_API_KEY=dein-geheimer-api-key-hier

# Admin-Login (V4-P-Auth). Passwort-Hash im Format scrypt$<salt>$<hash> --
# erzeugen mit: uv run python scripts/hash_password.py. Der Klartext gehoert
# NIE ins Repo. Leer = Admin-Login deaktiviert (nur API-Key-Zugriff moeglich).
AECT_ADMIN_PASSWORD_HASH=scrypt$0000$0000
# Session-Cookie Secure-Flag: Default aus (localhost-Demo ueber http). Hinter
# HTTPS auf true setzen. AECT_SESSION_COOKIE_SECURE=true
# AECT_SESSION_COOKIE_SECURE=false

# Azure OpenAI (Phase C, ADR-0010) -- auskommentiert bis Credentials verfuegbar.
# EU-Data-Zone-Pflicht (ADR-0003): Deployment muss in swedencentral oder
# westeurope liegen.
# AECT_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AECT_AZURE_OPENAI_API_KEY=<dein-azure-api-key>
# AECT_AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
# AECT_AZURE_OPENAI_API_VERSION=2024-10-21
# AECT_AZURE_OPENAI_REGION=swedencentral  # optional, siehe AUDIT-008

# ChromaDB (Phase D). Default 127.0.0.1 -- nur bei abweichendem Chroma-Host
# setzen. Kein stiller MockRetriever-Fallback mehr: ist der Container nicht
# erreichbar, faellt der Retriever fail-loud aus (V4-P2). Container starten:
# docker compose up -d && uv run python scripts/seed_knowledge_base.py
# AECT_CHROMA_HOST=127.0.0.1
# AECT_CHROMA_PORT=8001
